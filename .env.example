# BabyBase Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Django Core
# =============================================================================

# Runtime environment: development, local, test, staging, production
APP_ENV=development

# SECURITY WARNING: Generate a unique secret key for production
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# PostgreSQL Database
# =============================================================================

DB_NAME=babybase
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Connection pooling (recommended: 600 for production)
CONN_MAX_AGE=600

# Enable connection health checks (recommended: True)
CONN_HEALTH_CHECKS=True

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================

# Comma-separated list of allowed origins for the frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# Qdrant (Vector Database)
# =============================================================================

# Qdrant Cloud URL (e.g., https://your-cluster.cloud.qdrant.io:6333)
QDRANT_URL=

# Qdrant Cloud API key
QDRANT_API_KEY=

# Qdrant collection name for baby names
QDRANT_COLLECTION=names_global_v1

# =============================================================================
# AWS Bedrock
# =============================================================================

# AWS region for Bedrock Runtime API (Nova Embed model)
AWS_BEDROCK_REGION=us-east-1

# =============================================================================
# Phonetic "Sounds Like" (Nova + Polly + S3)
# =============================================================================

# Amazon Bedrock Nova model used to generate cached phonetic profiles
NOVA_MODEL_ID=amazon.nova-lite-v1:0

# S3 bucket for storing Amazon Polly pronunciation audio (provisioned by infra)
PRONUNCIATION_AUDIO_BUCKET=

# Amazon Polly neural voice used to synthesize pronunciation audio
PRONUNCIATION_VOICE=Joanna

# Time-to-live (seconds) for presigned pronunciation audio URLs
PRONUNCIATION_URL_TTL_SECONDS=3600
